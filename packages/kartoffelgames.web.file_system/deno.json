{
    "name": "@kartoffelgames/web-file-system",
    "version": "1.0.1",
    "license": "LGPL-3.0-only",
    "tasks": {},
    "imports": {
        "@std/testing": "jsr:@std/testing@^1.0.9",
        "@std/expect": "jsr:@std/expect@^1.0.13"
    },
    "exports": {
        ".": "./source/index.ts"
    },
    "publish": {
        "include": [
            "source/",
            "deno.json",
            "LICENSE"
        ]
    },
    "kg": {
        "name": "Kartoffelgames.Web.File_System",
        "config": {
            "package-blueprint": "kg-main",
            "bundle": {
                "enabled": false,
                "bundleSettingsFile": ""
            },
            "scratchpad": {
                "bundleSettingsFile": "",
                "mainBundleRequired": false,
                "port": 8088
            },
            "page": {
                "enabled": false,
                "bundleSettingsFile": "",
                "mainBundleRequired": false,
                "port": 8088
            },
            "test": {
                "directory": "./test"
            },
            "transform": {
                "enableNode": false,
                "nodeDirectory": "./node"
            }
        },
        "source": "./source"
    }
}